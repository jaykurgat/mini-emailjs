# ════════════════════════════════════════════
# Mini-EmailJS — Environment Variables
#
# Copy this file to ".env" for local development
# (used by scripts/create-project.js).
#
# In production, set these in your Vercel project
# settings under "Environment Variables" — do NOT
# commit a real .env file to git.
# ════════════════════════════════════════════

# Supabase project URL
# Found in: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (SECRET — server-side only, never expose to browsers)
# Found in: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend API key
# Found in: Resend Dashboard → API Keys
RESEND_API_KEY=re_your_resend_api_key_here
